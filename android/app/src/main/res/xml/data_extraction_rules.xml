<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+) backup/transfer rules. Belt-and-braces with
     android:allowBackup="false": exclude every data domain from BOTH cloud
     backup and device-to-device transfer so the encrypted vault blob never
     leaves the device by any backup channel (threat model H5). The hardware
     Keystore key is non-exportable regardless, but we deny the ciphertext too. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
